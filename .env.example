# ─── Servidor WhatsApp — Agente Márcia ───────────────────
# Copie este arquivo para .env e preencha os valores

# Porta do servidor (Railway/Render usam a variável PORT automaticamente)
PORT=3000

# Chave de API para autenticar requisições
# Gere uma chave forte: https://randomkeygen.com/
API_KEY=lidar-wpp-key-mude-isso-aqui

# URL do Worker Cloudflare que vai receber as mensagens do WhatsApp
WEBHOOK_URL=https://lidar-erp-api.lidar-erp.workers.dev/marcia/webhook
